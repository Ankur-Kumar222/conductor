      },
      "Intent": {
        "properties": {
          "services": {
            "items": {
              "type": "string",
              "enum": [
                "gmail",
                "gcal",
                "drive"
              ]
            },
            "type": "array",
            "title": "Services",
            "description": "services this query touches"
          },
          "intent": {
            "type": "string",
            "title": "Intent",
            "description": "short snake_case intent label, e.g. search_email, cancel_flight"
          },
          "entities": {
            "items": {
              "$ref": "#/components/schemas/Entity"
            },
            "type": "array",
            "title": "Entities"
          },
          "needs_clarification": {
            "type": "boolean",
            "title": "Needs Clarification",
            "description": "true only if the query is too ambiguous to act on"
          },
          "clarification_question": {
            "type": "string",
            "title": "Clarification Question",
            "description": "question to ask the user, or '' if none"
          }
        },
        "type": "object",
        "required": [
          "services",
          "intent",
          "entities",
          "needs_clarification",
          "clarification_question"
