# ---- Database (local Postgres + pgvector) ----
# Async driver URL used by the app (SQLAlchemy + asyncpg)
DATABASE_URL="postgresql+asyncpg://ankur@localhost:5432/conductor"
# Sync driver URL used by Alembic migrations
SYNC_DATABASE_URL="postgresql+psycopg2://ankur@localhost:5432/conductor"

# ---- OpenAI ----
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1/"
OPENAI_CHAT_MODEL="gpt-5"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIM=1536

# ---- Google OAuth (Web application client) ----
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="..."
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# ---- App ----
FRONTEND_URL="http://localhost:5173"
SYNC_LOOKBACK_DAYS=90
SYNC_MAX_ITEMS_PER_SERVICE=200
